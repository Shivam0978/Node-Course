 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Home</title>
  <link rel="stylesheet" href="/output.css">
</head>
<body class="ml-2">
  
   <%- include('partials/nav') %>     <!-- partials -->

  <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">

    <h2 class="text-3xl font-bold mb-8 text-center text-red-600">
        Register your home
    </h2>

    <form
        action="/host/add-home"
        method="POST"
        class="max-w-md mx-auto flex flex-col items-center gap-5"
    >
<!-- <input class=" text-sm" type="text" placeholder="Enter your house name" name="HouseName"><br>
<input class="mb-2 text-sm" type="text" placeholder="Enter house address" name=" House Address"><br> -->

<!-- <input class=" text-sm" type="text" placeholder="Enter your house name" name="House-Name"><br>
<input class="mb-2 text-sm" type="text" placeholder="Enter house address" name=" House-Address"><br> -->

        <input
            class="w-full px-4 py-3 border rounded-md
                   focus:outline-none focus:ring-2 focus:ring-red-500"
            type="text"
            placeholder="Enter your house name"
            name="HouseName"
        >

        <input
            class="w-full px-4 py-3 border rounded-md
                   focus:outline-none focus:ring-2 focus:ring-red-500"
            type="text"
            placeholder="Enter Location"
            name="HouseAddress"
        >

        <input class="w-full px-4 py-3 border rounded-md
                   focus:outline-none focus:ring-2 focus:ring-red-500"
        type="number" 
        name="price" 
        placeholder="Price Per Night">

        <input class="w-full px-4 py-3 border rounded-md
                   focus:outline-none focus:ring-2 focus:ring-red-500"
         type="text"
        name="City"
        placeholder="Enter City">

         <input class="w-full px-4 py-3 border rounded-md
                   focus:outline-none focus:ring-2 focus:ring-red-500"
         type="text"
        name="photoURL"
        placeholder="Enter photo URL">

        

        <input
            type="submit"
            value="Submit"
            class="w-full bg-red-500 text-white
                   py-3 rounded-md font-semibold
                   hover:bg-red-600 transition duration-300
                   cursor-pointer"
        >

    </form>

</main>
</body>
</html> 



