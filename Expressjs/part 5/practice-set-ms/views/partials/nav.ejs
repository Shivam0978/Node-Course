 <header class="bg-red-500 text-white p-4 shadow-md" >
    <nav class="container mx-auto flex flex-wrap justify-between items-center ">
      <ul class="flex flex-wrap gap-2 text-sm">

         <li>
    <a href ="/store/" class="<%= currentPage=== 'airbnb' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Airbnb</a>
    </li>
         <li>
    <a href ="/store/home-list" class="<%= currentPage=== 'home' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Home List</a>
    </li>
    <li>
      <a href="/store/favourite-list"
      class="<%= currentPage==='favourite' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Favourite</a>
    </li>

     <li>
      <a href="/store/booking"
      class="<%= currentPage==='bookings' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Bookings</a>
    </li>
     <li>
    <a href ="/host/host-home-list" class="<%= currentPage=== 'host-home' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Host Home</a>
    </li>
     <li>
    <a href ="/host/add-home" class="<%= currentPage=== 'add-home' ? 'bg-red-400':' hover:bg-red-400' %> py-2 px-4 rounded transition duration-300">Add Home</a>
    </li>

      </ul>
    </nav>
     </header>  

     <!-- class="<%= currentPage=== 'home' ? 'bg-red-400':' hover:bg-red-400' %> 
      
     this is because of the effect that the buttons like home and add home at nav bar will be active when user is at that page-->