

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>home</title>

  <!--<link rel="stylesheet" href="home.css">  --> <!--just add the name of css file in public-->
  <link rel="stylesheet" href="output.css">    <!--for tailwindcss-->
</head>
<body>
  <header class="bg-red-500 text-white p-4 shadow-md" >
    <nav class="container mx-auto flex justify-between items-center">
      <ul class="flex space-x-4 text-sm">
         <li>
    <a href ="/" class="hover:bg-red-400 py-2 px-4 rounded transition duration-300">Go to home</a>
    </li>
        <li>
    <a href ="/host/add-home" class="hover:bg-red-400 py-2 px-4 rounded transition duration-300">Add home</a>
    </li>
      </ul>
    </nav>
     </header>  
     <main class = "container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 font-semibold">
  <h2 class=" text-3xl text-center">Welcome to airbnb</h2> 
     </main>
  <ul class=" list-inside space-y-2" >
    <!-- Ejs code (just write what to do with js in <% %>) -->
     <% registerHomes.forEach(home =>{ %>  <!--from here html will start so %> should be necessary -->
      <li >
        <%= home['House Name'] %> 
        <%= home['House Address'] %>
      </li>

    <% }) %>
  </ul>
    
  
</body>
